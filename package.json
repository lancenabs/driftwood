{
  "name": "driftwood",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "qa:crisis": "node scripts/qa-crisis-check.mjs",
    "qa:crawl": "node scripts/qa-full-crawl.mjs",
    "qa:gathering": "node scripts/qa-gathering.mjs",
    "qa:all": "npm run lint && npm run qa:crisis && npm run qa:script && npm run qa:island-mirror && npm run qa:invite && npm run qa:crawl && npm run qa:gathering && npm run qa:bridge",
    "qa:bridge": "node scripts/qa-bridge.mjs",
    "qa:island-mirror": "node scripts/qa-island-mirror.mjs",
    "qa:invite": "node scripts/qa-invite.mjs",
    "qa:script": "node scripts/qa-script.mjs"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/d3": "^7.4.3",
    "@vitejs/plugin-react": "^5.0.4",
    "d3": "^7.9.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.9.2",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
